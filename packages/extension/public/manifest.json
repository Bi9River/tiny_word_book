{
	"manifest_version": 5,
	"name": "Tiny Word Book",
	"short_name": "tiny word book",
	"description": "Save words and sentences to your private GitHub-backed word book.",
	"version": "0.1.0",
	"permissions": ["storage", "contextMenus", "activeTab", "scripting"],
	"host_permissions": ["https://api.github.com/*"],
	"action": {
		"default_popup": "popup.html",
		"default_title": "Tiny Word Book"
	},
	"options_ui": {
		"page": "options.html",
		"open_in_tab": true
	},
	"background": {
		"service_worker": "background.js",
		"type": "module"
	},
	"commands": {
		"save-selection": {
			"suggested_key": {
				"default": "Ctrl+Shift+K",
				"mac": "Command+Shift+K"
			},
			"description": "Save selected text to Tiny Word Book"
		}
	},
	"icons": {
		"16": "icons/icon-16.png",
		"32": "icons/icon-32.png",
		"48": "icons/icon-48.png",
		"128": "icons/icon-128.png"
	}
}
