{
	"name": "tiny-word-book",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"dev": "npm run dev -w @tiny-word-book/web",
		"build": "npm run build -w @tiny-word-book/web",
		"preview": "npm run preview -w @tiny-word-book/web",
		"check": "npm run check -w @tiny-word-book/web",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write ."
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.0",
		"typescript-eslint": "^8.60.1"
	}
}
